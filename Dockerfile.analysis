FROM opensandbox/code-interpreter:v1.0.2

# Install analysis packages (pre-baked into image — no runtime pip install needed)
# Install into CodeInterpreter kernel's Python 3.11 (not system Python 3.12)
RUN /opt/python/versions/cpython-3.11.14-linux-x86_64-gnu/bin/python3 -m pip install --no-cache-dir --break-system-packages \
    pandas==2.2.3 \
    openpyxl==3.1.5 \
    xlsxwriter==3.2.0 \
    numpy==1.26.4 \
    matplotlib==3.9.4 \
    seaborn==0.13.2 \
    plotly==5.24.1 \
    scipy==1.13.1 \
    scikit-learn==1.5.2 \
    pydyf==0.10.0 \
    weasyprint==62.3 \
    pdfplumber==0.11.4 \
    duckdb==1.1.3 \
    fpdf2==2.8.1 \
    pillow==11.1.0 \
    python-pptx==1.0.2

# Pre-install DejaVu fonts for PDF generation (fpdf2 + weasyprint)
RUN apt-get update && apt-get install -y --no-install-recommends fonts-dejavu-core && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /home/sandbox \
    && cp /usr/share/fonts/truetype/dejavu/DejaVuSans.ttf /home/sandbox/DejaVuSans.ttf \
    && cp /usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf /home/sandbox/DejaVuSans-Bold.ttf

WORKDIR /home/sandbox
