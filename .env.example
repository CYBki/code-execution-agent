ANTHROPIC_API_KEY=sk-ant-...
# Must match api_key in docker/sandbox.toml — use a strong random value in production
OPEN_SANDBOX_API_KEY=<your-sandbox-api-key>
OPEN_SANDBOX_DOMAIN=localhost:8080

# PostgreSQL (used by docker-compose; omit DATABASE_URL for SQLite fallback in local dev)
POSTGRES_PASSWORD=<your-postgres-password>
# DATABASE_URL=postgresql://agentic:<your-postgres-password>@127.0.0.1:5432/agentic